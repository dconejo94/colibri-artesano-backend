<mxfile host="app.diagrams.net" modified="2026-05-14T00:00:00.000Z" agent="draw.io" version="24.0.0" type="device">
  <diagram id="checkout" name="Flujo GET /products (Secuencia)">
    <mxGraphModel dx="1422" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1100" math="0" shadow="1">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- TITLE -->
        <mxCell id="title" value="&lt;font style=&quot;font-size:18px;&quot;&gt;&lt;b&gt;Colibrí Artesano — Diagrama de Secuencia: Flujo principal de datos&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;i&gt;GET /api/v1/products · Único endpoint implementado · Transacción de lectura con SQLAlchemy Async&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="1000" height="50" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- PARTICIPANT HEADERS -->
        <!-- ============================================================ -->
        <mxCell id="p1_head" value="&lt;b&gt;📱 App Móvil&lt;/b&gt;&lt;br&gt;(React Native + Expo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;strokeWidth=2;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p2_head" value="&lt;b&gt;🔵 API Layer&lt;/b&gt;&lt;br&gt;(FastAPI Router)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="270" y="70" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p3_head" value="&lt;b&gt;🟢 Service Layer&lt;/b&gt;&lt;br&gt;(product_service)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;strokeWidth=2;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p4_head" value="&lt;b&gt;🟡 Repository&lt;/b&gt;&lt;br&gt;(product_repo)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="730" y="70" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="p5_head" value="&lt;b&gt;🐘 PostgreSQL&lt;/b&gt;&lt;br&gt;(Azure Flexible Server)" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=2;fontSize=11;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="70" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- ============================================================ -->
        <!-- LIFELINES (vertical dashed lines) -->
        <!-- ============================================================ -->
        <mxCell id="l1" style="edgeStyle=none;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="115" y="130" as="sourcePoint"/><mxPoint x="115" y="950" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="l2" style="edgeStyle=none;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="345" y="130" as="sourcePoint"/><mxPoint x="345" y="950" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="l3" style="edgeStyle=none;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="575" y="130" as="sourcePoint"/><mxPoint x="575" y="950" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="l4" style="edgeStyle=none;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="805" y="130" as="sourcePoint"/><mxPoint x="805" y="950" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="l5" style="edgeStyle=none;rounded=0;html=1;strokeColor=#999999;strokeWidth=1;dashed=1;dashPattern=5 5;endArrow=none;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1035" y="130" as="sourcePoint"/><mxPoint x="1035" y="950" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- SEQUENCE MESSAGES -->
        <!-- ============================================================ -->

        <!-- Step 1: App → API: GET /api/v1/products -->
        <mxCell id="m1" value="1. GET /api/v1/products&lt;br&gt;&lt;i&gt;HTTPS · JSON&lt;/i&gt;" style="edgeStyle=none;rounded=0;html=1;strokeColor=#2C6CC4;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;align=center;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="115" y="175" as="sourcePoint"/><mxPoint x="345" y="175" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 2: API → deps: get_db() -->
        <mxCell id="m2_box" value="&lt;b&gt;Resolve deps&lt;/b&gt;&lt;br&gt;deps.get_db()&lt;br&gt;AsyncSession abierta" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;strokeWidth=1;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="270" y="195" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Step 3: API → Service: get_products() -->
        <mxCell id="m3" value="2. product_service.get_products(db, params)" style="edgeStyle=none;rounded=0;html=1;strokeColor=#82B366;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;align=center;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="345" y="280" as="sourcePoint"/><mxPoint x="575" y="280" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 4: Service → Repository: find_all() -->
        <mxCell id="m4" value="3. product_repo.find_all(db, skip, limit)" style="edgeStyle=none;rounded=0;html=1;strokeColor=#D6B656;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;align=center;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="575" y="340" as="sourcePoint"/><mxPoint x="805" y="340" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 5: Repository → PostgreSQL: SELECT -->
        <mxCell id="m5" value="4. SELECT * FROM products&lt;br&gt;&lt;b&gt;LIMIT ? OFFSET ?&lt;/b&gt;&lt;br&gt;&lt;i&gt;(asyncpg, TCP :5432)&lt;/i&gt;" style="edgeStyle=none;rounded=0;html=1;strokeColor=#6C8EBF;strokeWidth=2;endArrow=block;endFill=1;fontSize=9;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="805" y="400" as="sourcePoint"/><mxPoint x="1035" y="400" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 6: PostgreSQL → Repository: rows -->
        <mxCell id="m6" value="Rows ✅" style="edgeStyle=none;rounded=0;html=1;strokeColor=#82B366;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1035" y="460" as="sourcePoint"/><mxPoint x="805" y="460" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 7: Repository → Service: List[Product] -->
        <mxCell id="m7" value="List[Product] ORM objects" style="edgeStyle=none;rounded=0;html=1;strokeColor=#82B366;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="805" y="520" as="sourcePoint"/><mxPoint x="575" y="520" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 8: Service → API: PaginatedResponse -->
        <mxCell id="m8" value="PaginatedResponse[ProductResponse]&lt;br&gt;&lt;i&gt;(Pydantic serialization)&lt;/i&gt;" style="edgeStyle=none;rounded=0;html=1;strokeColor=#82B366;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="575" y="590" as="sourcePoint"/><mxPoint x="345" y="590" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Session closed -->
        <mxCell id="m9_box" value="AsyncSession cerrada&lt;br&gt;(context manager)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=1;fontSize=9;align=center;" vertex="1" parent="1">
          <mxGeometry x="270" y="610" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- Step 9: API → App: 200 OK -->
        <mxCell id="m10" value="5. HTTP 200 OK&lt;br&gt;&lt;i&gt;{items: [...], total, page, size}&lt;/i&gt;" style="edgeStyle=none;rounded=0;html=1;strokeColor=#2C6CC4;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="345" y="690" as="sourcePoint"/><mxPoint x="115" y="690" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ============================================================ -->
        <!-- NOTE -->
        <!-- ============================================================ -->
        <mxCell id="note" value="&lt;b&gt;📌 Nota sobre el estado actual:&lt;/b&gt;&lt;br&gt;&lt;br&gt;Este es el único flujo de datos completamente&lt;br&gt;implementado en el repositorio.&lt;br&gt;&lt;br&gt;No existe aún: autenticación JWT, checkout,&lt;br&gt;gestión de pedidos, carrito, ni notificaciones.&lt;br&gt;Estos son pasos futuros del MVP." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#FFF2CC;strokeColor=#D6B656;strokeWidth=2;fontSize=10;align=left;spacingLeft=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="770" width="380" height="190" as="geometry"/>
        </mxCell>

        <mxCell id="latency_note" value="&lt;b&gt;⏱️ Latencia Esperada (lectura):&lt;/b&gt;&lt;br&gt;&lt;br&gt;Total end-to-end: ≤ 200ms&lt;br&gt;• DB query (SELECT): ~20-50ms&lt;br&gt;• Pydantic serialization: ~5ms&lt;br&gt;• Red (TLS): variable&lt;br&gt;&lt;br&gt;Sin caché de ningún tipo implementado." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;size=18;fillColor=#E6F3FF;strokeColor=#4A90D9;strokeWidth=2;fontSize=10;align=left;spacingLeft=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="460" y="770" width="360" height="190" as="geometry"/>
        </mxCell>

      </root>
