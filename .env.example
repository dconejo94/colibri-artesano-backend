APP_NAME=Colibri Artesano API

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=colibri
POSTGRES_PORT=5432
POSTGRES_HOST=db
SQL_ECHO=False
DB_SSL_MODE=disable   # use "require" for managed instances (e.g. Azure PostgreSQL)

ALLOWED_ORIGINS=["http://localhost:8081"]
BACKEND_PORT=8000

# JWT / auth
JWT_SECRET_KEY=change-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_RATE_LIMIT=5/minute