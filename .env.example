APP_NAME=Colibri Artesano API

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=colibri
POSTGRES_PORT=5432
POSTGRES_HOST=db
SQL_ECHO=False
DB_SSL_MODE=disable   # use "require" for managed instances (e.g. Azure PostgreSQL)

ALLOWED_ORIGINS=["http://localhost:8081"]
BACKEND_PORT=8000

# JWT / auth
JWT_SECRET_KEY=change-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_RATE_LIMIT=5/minute

# Azure Blob Storage (product images) — leave name/key blank locally (endpoint returns 503 until set)
AZURE_STORAGE_ACCOUNT_NAME=                    # the name of your Azure Storage account (the bucket's "owner")
AZURE_STORAGE_ACCOUNT_KEY=                     # the secret key used to SIGN upload URLs (like a master password)
AZURE_STORAGE_CONTAINER=product-images         # the "folder"/bucket inside the account where images live

# Azure Monitor / Application Insights — leave blank locally (telemetry stays off until set)
APPLICATIONINSIGHTS_CONNECTION_STRING=         # connection string from the colibri-insights resource; enables request tracing